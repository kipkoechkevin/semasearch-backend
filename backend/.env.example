# Environment
NODE_ENV=development

# API Keys (REQUIRED)
JINA_API_KEY=your_jina_api_key_here
API_KEY=your_secure_random_api_key_here

# Server
PORT=3000
DATA_DIR=./data

# CORS - Configure allowed origins
# Options:
# 1. Allow all (development only): *
# 2. Single domain: https://your-site.com
# 3. Multiple domains (comma-separated): https://site1.com,https://site2.com,https://site3.com
# 4. Wildcard subdomain pattern: Use option 3 with all subdomains listed
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Request Limits
REQUEST_TIMEOUT_MS=30000
MAX_REQUEST_SIZE=10mb

# Business Logic
MAX_FREE_PRODUCTS=500
MAX_PRODUCTS_PER_BATCH=100

# Embedding Cache (per site)
MAX_CACHE_SIZE=10000

# Search Score Threshold (0.0 - 1.0)
SCORE_THRESHOLD=0.5

# Logging
LOG_LEVEL=info
